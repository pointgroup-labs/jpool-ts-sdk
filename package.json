{
  "name": "@jpool/sdk",
  "version": "0.1.2",
  "packageManager": "pnpm@11.3.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "release": "release-it",
    "release:ci": "release-it --ci -i patch -VV",
    "release:dry": "release-it --ci --dry-run -i patch",
    "release:pre": "release-it --preRelease=next -VV",
    "release:pre:dry": "release-it --preRelease=next --dry-run --ci"
  },
  "dependencies": {
    "@jpool/spl-stake-pool": "^1.1.10",
    "@solana/spl-memo": "^0.2.5",
    "@solana/web3.js": "^1.98.4",
    "axios": "^1.16.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@release-it/conventional-changelog": "^11.0.0",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-plugin-format": "^2.0.1",
    "release-it": "^20.0.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
