{
  "name": "@jpool/sdk",
  "version": "0.1.1",
  "packageManager": "pnpm@10.22.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "release": "release-it",
    "release:ci": "release-it --ci -i patch -VV",
    "release:dry": "release-it --ci --dry-run -i patch",
    "release:pre": "release-it --preRelease=next -VV",
    "release:pre:dry": "release-it --preRelease=next --dry-run --ci"
  },
  "dependencies": {
    "@solana/spl-memo": "^0.2.5",
    "@solana/spl-stake-pool": "^1.1.8",
    "@solana/web3.js": "^1.98.4",
    "axios": "^1.13.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.2.0",
    "@release-it/conventional-changelog": "^10.0.2",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "eslint-plugin-format": "^1.0.2",
    "release-it": "^19.0.6",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@solana/spl-stake-pool": "https://github.com/mfactory-lab/spl-stake-pool.git#7607823"
    }
  }
}
